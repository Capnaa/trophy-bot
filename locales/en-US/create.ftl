# /create — en-US catalog (batch C1).

# Validation errors (legacy limits, checked server-side before any persistence — F3).
create-error-name-empty = The trophy needs a name with at least one visible character.
create-error-name-too-long = The name of the trophy can't be longer than { $max } characters.
create-error-details-too-long = The details of the trophy can't be longer than { $max } characters.
create-error-description-too-long = The description of the trophy can't be longer than { $max } characters.
create-error-emoji-too-long = The emoji of the trophy can't be longer than { $max } characters.
create-error-dedication-too-long = The dedication of the trophy can't be longer than { $max } characters.
create-error-category-too-long = The category of the trophy can't be longer than { $max } characters.
create-error-value-out-of-range = The value of the trophy must be between { $min } and { $max }.
create-error-guild-full = This server already has { $max } trophies. Delete one before creating a new one.
create-error-duplicate-name = A trophy named "{ $name }" already exists in this server. Trophy names must be unique.
create-error-image-type = The trophy image must be a PNG, JPG, JPEG or GIF file.
create-error-image-too-large = The trophy image can't be larger than 1 MB.
create-error-image-download = I couldn't download the trophy image. Please try again.

# Success embed.
create-field-value = Value
create-value = 🏅 { $value }
create-field-signed = Signed by
create-field-dedicated = Dedicated to
create-field-category = Category
create-footer = Trophy: { $name }
