# /forgetme — en-US catalog (batch C16, F33).
# NOTE: Fluent continuation lines must not start with `*`/`[`/`.` — keep
# every value on a single line.

forgetme-not-owner = Only the **server owner** can ask me to forget this server.

forgetme-warning-title = ⚠️ Delete all server data?
forgetme-warning-description = This will permanently delete **every trophy, award, setting, role reward and leaderboard panel** for this server, remove all stored trophy images, and I will **leave the server**. This action cannot be undone. The buttons below expire in { $seconds } seconds.
forgetme-button-confirm = Delete all server data
forgetme-button-cancel = Cancel

forgetme-cancelled-title = ✅ Cancelled
forgetme-cancelled = Phew! Nothing was deleted — your server's data is safe.

forgetme-expired-title = ⌛ Confirmation expired
forgetme-expired = This confirmation has expired. Run /forgetme again if you still want me to delete this server's data.

forgetme-goodbye-title = 🧹 All data deleted
forgetme-goodbye = Every trophy, award, setting and image for this server has been deleted. Goodbye! 👋
